## 3. LangGraph Agent Orchestration

### 3.1 Multi-Agent Architecture

```python
from langgraph.graph import StateGraph, END
from langgraph.checkpoint.memory import MemorySaver

class NutrifAIAgentSystem:
    """
    Complete multi-agent system using LangGraph for orchestration
    Based on: LLM Agent Survey (2023) + domain-specific optimizations
    """
    
    def __init__(self):
        self.memory_system = HierarchicalMemorySystem()
        self.rag_system = PersonalizedRAGSystem()
        self.code_agent = CodeActionAgent()
        self.cost_optimizer = CostOptimizer()
        
        # Create the agent workflow
        self.workflow = self._create_agent_workflow()
        self.memory = MemorySaver()
        self.compiled_graph = self.workflow.compile(checkpointer=self.memory)
        
    def _create_agent_workflow(self) -> StateGraph:
        """Create the complete agent workflow with specialized nodes"""
        
        workflow = StateGraph(AgentState)
        
        # Core agent nodes
        workflow.add_node("context_optimizer", self.optimize_context)
        workflow.add_node("retrieval_agent", self.retrieve_information)
        workflow.add_node("nutrition_specialist", self.nutrition_reasoning)
        workflow.add_node("fitness_specialist", self.fitness_reasoning)
        workflow.add_node("behavior_analyst", self.behavior_analysis)
        workflow.add_node("response_synthesizer", self.synthesize_response)
        workflow.add_node("cost_analyzer", self.analyze_costs)
        workflow.add_node("quality_checker", self.validate_response)
        
        # Set up the workflow
        workflow.set_entry_point("context_optimizer")
        
        # Context optimization → Information retrieval
        workflow.add_edge("context_optimizer", "retrieval_agent")
        
        # Conditional routing to specialists
        workflow.add_conditional_edges(
            "retrieval_agent",
            self.route_to_specialists,
            {
                "nutrition": "nutrition_specialist",
                "fitness": "fitness_specialist",
                "behavior": "behavior_analyst", 
                "multi_domain": "response_synthesizer"
            }
        )
        
        # All specialists route to synthesizer
        workflow.add_edge("nutrition_specialist", "response_synthesizer")
        workflow.add_edge("fitness_specialist", "response_synthesizer")
        workflow.add_edge("behavior_analyst", "response_synthesizer")
        
        # Response synthesis → Cost analysis → Quality check
        workflow.add_edge("response_synthesizer", "cost_analyzer")
        workflow.add_edge("cost_analyzer", "quality_checker")
        
        # Quality gate
        workflow.add_conditional_edges(
            "quality_checker",
            self.quality_gate,
            {
                "approved": END,
                "needs_revision": "retrieval_agent",  # Loop back for improvement
                "cost_too_high": "context_optimizer"   # Reduce context and retry
            }
        )
        
        return workflow
        
    async def optimize_context(self, state: AgentState) -> AgentState:
        """Optimize context to balance relevance and cost"""
        
        user_id = state.user_id
        query = state.user_query
        
        # Load hierarchical memory
        working_memory = await self.memory_system.working_memory.get_current_context(user_id)
        
        # Retrieve relevant episodic memories
        episodic_context = await self.memory_system.episodic_memory.retrieve_relevant_episodes(
            query, max_tokens=4000
        )
        
        # Get compressed semantic knowledge
        semantic_context = await self.memory_system.semantic_memory.get_user_summary(user_id)
        
        # Convert to executable code format for efficiency
        code_context = self.code_agent.convert_context_to_code({
            "working_memory": working_memory,
            "episodic_context": episodic_context,
            "semantic_context": semantic_context
        })
        
        # Estimate token usage and costs
        estimated_tokens = self._estimate_tokens(code_context + query)
        estimated_cost = self.cost_optimizer.estimate_interaction_cost(
            input_tokens=estimated_tokens,
            output_tokens=500,  # Estimated response length
            model="gpt-4o"  # Default model
        )
        
        state.optimized_context = code_context
        state.estimated_tokens = estimated_tokens
        state.estimated_cost = estimated_cost
        
        return state
        
    async def retrieve_information(self, state: AgentState) -> AgentState:
        """Retrieve relevant information using corrective RAG"""
        
        rag_result = await self.rag_system.retrieve_and_generate(
            query=state.user_query,
            user_context=state.optimized_context
        )
        
        state.retrieved_information = rag_result["response"]
        state.retrieval_confidence = rag_result["confidence"]
        state.information_sources = rag_result["sources"]
        state.retrieval_strategy = rag_result["retrieval_strategy"]
        
        return state
        
    def route_to_specialists(self, state: AgentState) -> str:
        """Route query to appropriate specialist agents"""
        
        query = state.user_query.lower()
        
        # Simple keyword-based routing (can be enhanced with classification model)
        nutrition_keywords = ["eat", "meal", "food", "nutrition", "diet", "calorie", "macro"]
        fitness_keywords = ["workout", "exercise", "fitness", "gym", "strength", "cardio"]
        behavior_keywords = ["motivation", "habit", "stress", "sleep", "mood", "adherence"]
        
        domains = []
        if any(word in query for word in nutrition_keywords):
            domains.append("nutrition")
        if any(word in query for word in fitness_keywords):
            domains.append("fitness")
        if any(word in query for word in behavior_keywords):
            domains.append("behavior")
            
        if len(domains) > 1:
            return "multi_domain"
        elif len(domains) == 1:
            return domains[0]
        else:
            return "multi_domain"  # Default to multi-domain for unclear queries
            
    async def nutrition_specialist(self, state: AgentState) -> AgentState:
        """Specialized agent for nutrition recommendations"""
        
        nutrition_prompt = f"""
        You are a nutrition specialist AI. Using the provided user context and retrieved information,
        provide personalized nutrition advice.
        
        User Context (Executable):
        {state.optimized_context}
        
        Retrieved Information:
        {state.retrieved_information}
        
        User Query: {state.user_query}
        
        Provide specific, actionable nutrition recommendations considering:
        1. User's dietary restrictions and allergies
        2. Current health conditions and medications
        3. Personal preferences and cultural background
        4. Practical constraints (time, budget, cooking skills)
        5. Current goals and progress patterns
        
        Format as structured recommendations with reasoning.
        """
        
        response = await self._llm_call(
            prompt=nutrition_prompt,
            model=self._select_optimal_model(state),
            max_tokens=800
        )
        
        state.specialist_responses["nutrition"] = response
        return state
        
    async def fitness_specialist(self, state: AgentState) -> AgentState:
        """Specialized agent for fitness recommendations"""
        
        fitness_prompt = f"""
        You are a fitness specialist AI. Using the provided user context and retrieved information,
        provide personalized fitness advice.
        
        User Context (Executable):
        {state.optimized_context}
        
        Retrieved Information:
        {state.retrieved_information}
        
        User Query: {state.user_query}
        
        Provide specific, actionable fitness recommendations considering:
        1. User's fitness experience and current capabilities
        2. Available equipment and time constraints  
        3. Injuries or physical limitations
        4. Current readiness and recovery status
        5. Personal preferences and motivation patterns
        
        Format as structured workout plans or exercise modifications with safety notes.
        """
        
        response = await self._llm_call(
            prompt=fitness_prompt,
            model=self._select_optimal_model(state),
            max_tokens=800
        )
        
        state.specialist_responses["fitness"] = response
        return state
        
    async def behavior_analyst(self, state: AgentState) -> AgentState:
        """Specialized agent for behavioral coaching and motivation"""
        
        behavior_prompt = f"""
        You are a behavioral psychology specialist AI. Using the provided user context and retrieved information,
        provide personalized behavioral coaching.
        
        User Context (Executable):
        {state.optimized_context}
        
        Retrieved Information:
        {state.retrieved_information}
        
        User Query: {state.user_query}
        
        Provide specific, actionable behavioral recommendations considering:
        1. User's personality traits and communication preferences
        2. Historical behavior patterns and success/failure modes
        3. Current psychological state and motivation levels
        4. Environmental factors and social influences
        5. Habit formation strategies and intervention timing
        
        Format as personalized coaching advice with specific action steps.
        """
        
        response = await self._llm_call(
            prompt=behavior_prompt,
            model=self._select_optimal_model(state),
            max_tokens=600
        )
        
        state.specialist_responses["behavior"] = response
        return state
        
    def _select_optimal_model(self, state: AgentState) -> str:
        """Select optimal model based on complexity and cost constraints"""
        
        # Model selection based on estimated cost and query complexity
        if state.estimated_cost > 0.10:  # High cost threshold
            return "gpt-4o-mini"  # Use cheaper model
        elif "complex" in state.user_query.lower() or len(state.user_query) > 200:
            return "gpt-4o"  # Use balanced model for complex queries
        else:
            return "gpt-4o-mini"  # Default to cost-effective model
