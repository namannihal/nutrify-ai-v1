    """Smart caching system that reduces API calls by ~70%"""
    
    def __init__(self):
        self.redis_client = Redis()
        self.similarity_threshold = 0.85
        
    async def check_semantic_cache(self, query: str, user_id: str) -> dict:
        """Check for semantically similar cached responses"""
        
        # Generate embedding for current query
        query_embedding = await self._embed_query(query)
        
        # Search user's cache for similar queries
        cache_key = f"user_cache:{user_id}"
        cached_items = await self.redis_client.hgetall(cache_key)
        
        for cached_query_hash, cached_data in cached_items.items():
            cached_item = json.loads(cached_data)
            
            # Calculate semantic similarity
            similarity = self._cosine_similarity(
                query_embedding, cached_item["embedding"]
            )
            
            # Check temporal relevance
            cache_age_hours = (datetime.now() - 
                             datetime.fromisoformat(cached_item["timestamp"])).total_seconds() / 3600
            
            # Determine if cache is still valid
            if similarity > self.similarity_threshold and self._is_cache_valid(
                cached_item["query_type"], cache_age_hours
            ):
                # Update cache hit metrics
                await self._update_cache_metrics(user_id, "hit")
                
                return {
                    "response": cached_item["response"],
                    "similarity": similarity,
                    "cache_age_hours": cache_age_hours,
                    "cost_saved": cached_item["original_cost"]
                }
                
        # No valid cache found
        await self._update_cache_metrics(user_id, "miss")
        return None
        
    def _is_cache_valid(self, query_type: str, age_hours: float) -> bool:
        """Determine cache validity based on content type and age"""
        
        validity_periods = {
            "meal_planning": 24,        # Meal plans valid for 24 hours
            "workout_routine": 168,     # Workouts valid for 1 week
            "progress_analysis": 6,     # Progress updates every 6 hours
            "general_advice": 720,      # General advice valid for 1 month
            "goal_setting": 2160,       # Goals valid for 3 months
        }
        
        max_age = validity_periods.get(query_type, 24)  # Default 24 hours
        return age_hours <= max_age


