### 2.2 Corrective RAG System for Personalized Retrieval

Based on *"Corrective Retrieval Augmented Generation"*:

```python
class PersonalizedRAGSystem:
    """
    Advanced RAG system with corrective mechanisms for nutrition/fitness data
    Based on: CRAG (2024) + domain-specific optimizations
    """
    
    def __init__(self):
        self.personal_vector_store = ChromaDB()    # User's personal knowledge base
        self.general_knowledge_store = ChromaDB()  # Nutrition/fitness general knowledge
        self.retrieval_evaluator = RetrievalEvaluator()
        self.web_fallback = NutritionWebSearch()
        
    async def retrieve_and_generate(self, query: str, user_context: dict) -> dict:
        """Enhanced RAG with quality assessment and corrective actions"""
        
        # Stage 1: Personal knowledge retrieval
        personal_docs = await self._retrieve_personal_knowledge(query, user_context)
        
        # Stage 2: Evaluate retrieval quality
        retrieval_confidence = await self.retrieval_evaluator.assess_quality(
            query, personal_docs, user_context
        )
        
        # Stage 3: Apply corrective strategies if confidence is low
        if retrieval_confidence < 0.7:
            enhanced_docs = await self._corrective_retrieval(
                query, personal_docs, user_context
            )
        else:
            enhanced_docs = personal_docs
            
        # Stage 4: Decompose and recompose for focused information
        focused_context = await self._decompose_recompose(enhanced_docs, query)
        
        # Stage 5: Generate response with optimized context
        response = await self._generate_with_context(query, focused_context, user_context)
        
        return {
            "response": response,
            "confidence": retrieval_confidence,
            "sources": [doc.metadata for doc in enhanced_docs],
            "retrieval_strategy": "corrective" if retrieval_confidence < 0.7 else "standard",
            "cost_breakdown": self._calculate_costs(query, focused_context, response)
        }
        
    async def _corrective_retrieval(self, query: str, poor_docs: list, user_context: dict) -> list:
        """Apply multiple corrective strategies when primary retrieval fails"""
        
        corrections = []
        
        # Strategy 1: Query expansion with user-specific terms
        expanded_queries = await self._expand_query_with_profile(query, user_context)
        for expanded_query in expanded_queries:
            expanded_docs = await self._retrieve_personal_knowledge(expanded_query, user_context)
            corrections.extend(expanded_docs)
            
        # Strategy 2: Temporal context retrieval (different time periods)
        temporal_queries = [
            f"{query} recent patterns last 7 days",
            f"{query} monthly trends",
            f"{query} seasonal patterns"
        ]
        for temporal_query in temporal_queries:
            temporal_docs = await self._retrieve_personal_knowledge(temporal_query, user_context)
            corrections.extend(temporal_docs)
            
        # Strategy 3: Cross-domain retrieval (nutrition ↔ fitness correlation)
        if "nutrition" in query.lower():
            fitness_query = f"fitness exercise impact on {query}"
            fitness_docs = await self._retrieve_personal_knowledge(fitness_query, user_context)
            corrections.extend(fitness_docs)
        elif "fitness" in query.lower():
            nutrition_query = f"nutrition diet support for {query}"
            nutrition_docs = await self._retrieve_personal_knowledge(nutrition_query, user_context)
            corrections.extend(nutrition_docs)
            
        # Strategy 4: General knowledge fallback
        if len(corrections) < 3:
            general_docs = await self.general_knowledge_store.similarity_search(
                query, k=5, filter={"domain": ["nutrition", "fitness"]}
            )
            corrections.extend(general_docs)
            
        # Strategy 5: Web search for latest information (last resort)
        if len(corrections) < 2:
            web_docs = await self.web_fallback.search_nutrition_fitness(query)
            corrections.extend(web_docs[:2])  # Limit web results
            
        return self._deduplicate_and_rank(corrections)
        
    async def _decompose_recompose(self, docs: list, query: str) -> str:
        """Extract and synthesize only relevant information from retrieved docs"""
        
        if not docs:
            return ""
            
        # Decompose: Extract relevant sections from each document
        relevant_sections = []
        for doc in docs:
            extraction_prompt = f"""
            From this document, extract only the information directly relevant to: "{query}"
            
            Document: {doc.page_content}
            
            Extract key facts, recommendations, or insights. Ignore irrelevant details.
            Return as bullet points.
            """
            
            extracted = await self.llm_call(
                prompt=extraction_prompt,
                model="gpt-4o-mini",  # Use cheaper model for extraction
                max_tokens=200
            )
            
            relevant_sections.append(extracted)
            
        # Recompose: Synthesize extracted information
        synthesis_prompt = f"""
        Synthesize these extracted insights into a coherent knowledge base for answering: "{query}"
        
        Extracted insights:
        {chr(10).join(relevant_sections)}
        
        Create a structured knowledge summary focusing on:
        1. Direct answers to the query
        2. Relevant context and constraints
        3. Actionable recommendations
        
        Keep concise and focused.
        """
        
        synthesized = await self.llm_call(
            prompt=synthesis_prompt,
            model="gpt-4o-mini",
            max_tokens=400
        )
        
        return synthesized
