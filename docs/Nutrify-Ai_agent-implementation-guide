class CostOptimizer:
    """
    Multi-strategy cost optimization for LLM API calls
    """
    
    # Current OpenAI pricing (per 1K tokens)
    MODEL_PRICING = {
        "gpt-4": {"input": 0.03, "output": 0.06},
        "gpt-4o": {"input": 0.0025, "output": 0.01},
        "gpt-4o-mini": {"input": 0.00015, "output": 0.0006}
    }
    
    def __init__(self):
        self.cache_manager = IntelligentCacheManager()
        self.batch_processor = BatchProcessor()
        
    async def optimize_interaction(self, user_query: str, context: dict) -> dict:
        """Apply comprehensive cost optimization strategies"""
        
        # Strategy 1: Cache Check (70% hit rate expected)
        cache_result = await self.cache_manager.check_semantic_cache(
            user_query, context["user_id"]
        )
        if cache_result:
            return {
                "response": cache_result["response"],
                "cost": 0.0,
                "cache_hit": True,
                "optimization": "cache"
            }
            
        # Strategy 2: Context Compression
        compressed_context = await self._compress_context_intelligently(context)
        token_reduction = len(context) - len(compressed_context)
        
        # Strategy 3: Model Selection
        optimal_model = self._select_model_by_complexity(user_query, compressed_context)
        
        # Strategy 4: Batch Processing Check  
        if self._can_batch(user_query):
            batch_id = await self.batch_processor.add_to_queue(
                user_query, compressed_context, optimal_model
            )
            return {
                "batch_id": batch_id,
                "estimated_delay": 30,  # seconds
                "optimization": "batch"
            }
            
        # Strategy 5: Progressive Response for Complex Queries
        if self._is_complex_query(user_query):
            return await self._progressive_response(user_query, compressed_context)
            
        # Execute optimized single request
        cost = self._calculate_cost(compressed_context, optimal_model)
        
        return {
            "context": compressed_context,
            "model": optimal_model,
            "estimated_cost": cost,
            "token_reduction": token_reduction,
            "optimization": "compressed"
        }
        
    async def _compress_context_intelligently(self, context: dict) -> dict:
        """Compress context while preserving essential information"""
        
        # Identify essential vs optional information
        essential_keys = [
            "allergies", "medical_conditions", "current_goals",
            "dietary_restrictions", "injuries", "medications"
        ]
        
        recent_keys = [
            "last_week_patterns", "current_stress_level", 
            "recent_adherence", "immediate_preferences"
        ]
        
        historical_keys = [
            "long_term_patterns", "seasonal_preferences",
            "historical_success_rates", "personality_scores"
        ]
        
        # Always include essential information
        compressed = {key: context.get(key) for key in essential_keys if key in context}
        
        # Include recent information with high relevance
        for key in recent_keys:
            if key in context:
                compressed[key] = context[key]
                
        # Selectively include historical information based on relevance
        context_relevance = self._calculate_historical_relevance(context)
        if context_relevance > 0.7:
            for key in historical_keys[:3]:  # Top 3 most relevant
                if key in context:
                    compressed[key] = context[key]
                    
        return compressed
        
    def _select_model_by_complexity(self, query: str, context: dict) -> str:
        """Select optimal model based on query complexity and context size"""
        
        complexity_score = 0
        
        # Query complexity indicators
        complex_keywords = [
            "analyze", "compare", "explain why", "what if", "predict",
            "complex", "detailed", "comprehensive", "multiple factors"
        ]
        
        complexity_score += sum(1 for keyword in complex_keywords if keyword in query.lower())
        
        # Context size factor
        context_size = len(json.dumps(context))
        if context_size > 5000:  # Large context
            complexity_score += 2
        elif context_size > 2000:  # Medium context
            complexity_score += 1
            
        # Model selection
        if complexity_score >= 4:
            return "gpt-4o"  # High complexity
        elif complexity_score >= 2:
            return "gpt-4o"  # Medium complexity 
        else:
            return "gpt-4o-mini"  # Low complexity
            
    async def _progressive_response(self, query: str, context: dict) -> dict:
        """Provide progressive responses for complex queries to manage costs"""
        
        # Step 1: Quick acknowledgment (very cheap)
        quick_response = await self._generate_quick_response(query, context)
        
        # Step 2: Identify information needs
        info_needs = await self._analyze_information_requirements(query, context)
        
        # Step 3: Targeted retrieval and response
        if info_needs["requires_deep_analysis"]:
            detailed_response = await self._generate_detailed_response(query, context)
            total_cost = quick_response["cost"] + detailed_response["cost"]
        else:
            detailed_response = None
            total_cost = quick_response["cost"]
            
        return {
            "quick_response": quick_response["content"],
            "detailed_response": detailed_response["content"] if detailed_response else None,
            "total_cost": total_cost,
