project_name = "nutrify"
environment  = "dev"
location     = "eastus"

# Supabase Database
supabase_database_url = "postgresql+asyncpg://postgres:YOUR_PASSWORD@db.sisnrhostkpolotacnjj.supabase.co:5432/postgres"

# Security
secret_key = "your-super-secret-jwt-key-min-32-chars"

# Google OAuth
google_client_id     = "your-google-client-id.apps.googleusercontent.com"
